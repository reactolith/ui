  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.mjs",
      "require": "./dist/editor.cjs"
    },
    "./recharts": {
      "types": "./dist/recharts.d.ts",
      "import": "./dist/recharts.mjs",
      "require": "./dist/recharts.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:release": "npm install --no-fund --no-audit && npm run typecheck && npm run build:lib --if-present",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "generate-web-types": "tsx scripts/generate-web-types.ts"
  },
